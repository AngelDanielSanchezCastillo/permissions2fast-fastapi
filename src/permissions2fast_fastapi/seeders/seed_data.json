{
    "role": {
        "name": "Admin",
        "description": "Administrator with full access to permissions management"
    },
    "category": {
        "name": "System Administration",
        "description": "Permissions for system management"
    },
    "permissions": [
        {
            "name": "manage_routes",
            "routes": [
                "/routes",
                "/routes/"
            ]
        },
        {
            "name": "manage_roles",
            "routes": [
                "/roles",
                "/roles/",
                "/roles/{role_id}",
                "/roles/{role_id}/permissions",
                "/roles/{role_id}/permissions/{permission_id}",
                "/roles/assign",
                "/roles/user/{user_id}",
                "/roles/user/{user_id}/role/{role_id}"
            ]
        },
        {
            "name": "manage_permissions",
            "routes": [
                "/permissions/categories",
                "/permissions",
                "/permissions/",
                "/permissions/{permission_id}",
                "/permissions/{permission_id}/routes",
                "/permissions/assign",
                "/permissions/user/{user_id}",
                "/permissions/user/{user_id}/permission/{permission_id}"
            ]
        }
    ]
}
